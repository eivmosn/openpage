{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "../../.cache/tsbuildinfo/editor.tsbuildinfo",
    "paths": {
      "@openpage/renderer": [
        "../renderer/src/index.ts"
      ]
    },
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist"
  },
  "include": [
    "tsdown.config.ts",
    "src/**/*.ts"
  ]
}
